# ---- Required ----
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/resume-builder
JWT_SECRET=change-me-to-a-long-random-string
PORT=5000

# ---- AI (optional — endpoints degrade to deterministic fallbacks without it) ----
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ---- Job providers (optional — sample data is used when none are set) ----
# Comma-separated Greenhouse board tokens (from boards.greenhouse.io/<token>)
# e.g. GREENHOUSE_BOARDS=stripe,gitlab,cloudflare,figma,vercel,duolingo,reddit,dropbox
GREENHOUSE_BOARDS=
# Comma-separated Lever company slugs (from jobs.lever.co/<slug>)
# e.g. LEVER_COMPANIES=zoox,octoenergy,whoop
LEVER_COMPANIES=

# Restrict job feeds to these countries (ISO codes). Set to "all" to disable.
# JOB_COUNTRIES=US,CA

# ---- Google sign-in (optional — button is hidden until configured) ----
# OAuth 2.0 Web client ID from Google Cloud Console → Credentials.
# The same value goes in the frontend as NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=

# ---- Email notifications (optional — in-app notifications work without it) ----
# Any SMTP provider works via nodemailer. Gmail example:
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_USER=you@gmail.com
#   SMTP_PASS=<app password from myaccount.google.com/apppasswords>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
# Sender shown to recipients, e.g. "Rolevant AI <you@gmail.com>" (defaults to SMTP_USER)
EMAIL_FROM=
# Used in email links back to the app
APP_URL=
