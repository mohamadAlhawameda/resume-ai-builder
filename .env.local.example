# Frontend environment (Next.js). Copy to .env.local to override defaults.

# Backend API base URL. Defaults to the deployed Render backend when unset.
# For local development against a local backend:
NEXT_PUBLIC_API_URL=http://localhost:5000

# Google OAuth client ID (Web application) from Google Cloud Console.
# The "Continue with Google" button only appears when this is set. Must match
# the backend's GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com